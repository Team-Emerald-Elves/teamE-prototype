datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/"
}

enum Roles {
  UnderWriter
  BusinessAnalyst
}

enum UserRoles {
  Administrator
  UnderWriter
  BusinessAnalyst
}

model ServiceRequests {
  id          Int       @id @default(autoincrement())
  created_at  DateTime  @default(now())
  assigned_at DateTime? @updatedAt
  assigned_id String?   @db.Uuid
  creator_id  String?   @db.Uuid
  description String    @default("no description")
}

model Employee {
  id          String      @id @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkUserId String?
  uname       String      @unique @default("uname")
  first_name  String      @default("fname")
  last_name   String      @default("lname")
  roles       UserRoles[]
  email       String?     @unique
  bucket      BucketMeta?
  favorites   Int[]
}

model BucketMeta {
  id                 String        @id @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  public             Boolean       @default(false)
  type               String        @default("STANDARD")
  file_size_limit    Int           @default(10485760)
  allowed_mime_types String[]      @default([])
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt
  employeeId         String        @unique @db.Uuid
  employee           Employee      @relation(fields: [employeeId], references: [id])
  documentContents       documentContent[]
}

model documentContent {
  id              Int      @id @unique @default(autoincrement())
  name            String
  url             String?
  content_owner   String
  lock            String @default("none")
  assigned_role   UserRoles
  bucketId        String   @db.Uuid
  bucket          BucketMeta @relation(fields: [bucketId], references: [id])
  last_modified   DateTime @updatedAt
  expiration_date DateTime
  mime_type       String   @default("text/plain")
  document_status Status   @default(not_started)
  document_type   String
  favorite        Boolean @default(false)
}

model Links {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  link_name String
  url       String
  owner     String?
}

enum Status {
  not_started
  in_progress
  needs_review
  done
  expired
}