{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend (Express)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/backend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Frontend (Vite)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/frontend",
      "pathMapping": {
        "/": "${workspaceFolder}/apps/frontend"
      },
      "sourceMaps": true,
      "preLaunchTask": "start-vite"
    }
  ],
  "compounds": [
    {
      "name": "Launch Full Stack Prototype",
      "configurations": [
        "Debug Backend (Express)",
        "Debug Frontend (Vite)"
      ],
      "stopAll": true
    }
  ]
}