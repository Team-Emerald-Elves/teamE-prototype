{
  "name": "@repo/database",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "type": "module",
  "config": {
    "backendENV": "../../apps/backend/.env"
  },
  "scripts": {
    "db:generate": "dotenv -e $npm_package_config_backendENV -- pnpm prisma generate",
    "db:migrate": "dotenv -e $npm_package_config_backendENV -- pnpm prisma migrate dev",
    "db:push": "dotenv -e $npm_package_config_backendENV -- pnpm prisma db push",
    "db:studio": "dotenv -e $npm_package_config_backendENV -- pnpm prisma studio",
    "postinstall": "pnpm run db:generate",
    "prisma:generate": "dotenv -e $npm_package_config_backendENV -- pnpm prisma generate --schema=./prisma/schema.prisma",
    "db:pull": "dotenv -e $npm_package_config_backendENV -- pnpm prisma db pull",
    "db:pull:gen": "pnpm run db:pull && pnpm run db:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  }
}
