{
  "name": "backend-prototype",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "prisma generate",
    "start": "tsx src/index.ts",
    "dev": "pnpx bun run ./src/app.ts",
    "dk:start": "docker compose -f docker-compose.postgres.yml up -d",
    "seed": "ts-node prisma/seed.ts",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:pull": "pnpm --filter @repo/database db:pull",
    "db:pull:gen": "pnpm --filter @repo/database db:pull:gen"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/body-parser": "^1.19.6",
    "@types/bun": "latest",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "body-parser": "^2.2.2",
    "eslint": "^10.1.0",
    "globals": "^17.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.7",
    "@clerk/express": "^2.0.8",
    "@repo/database": "workspace:*",
    "@supabase/supabase-js": "^2.101.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "backend-prototype": "link:",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "mime": "^4.1.0",
    "morgan": "^1.10.1",
    "pnpm": "^10.33.0",
    "ts-node": "^10.9.2",
    "zod": "^4.3.6"
  }
}